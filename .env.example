SOLARK_USERNAME=your_email@example.com
SOLARK_PASSWORD=your_password
SOLARK_PLANT_ID=123456

LATITUDE=0.0
LONGITUDE=0.0
TZ_OFFSET=-6
OPENWEATHER_API_KEY=your_openweathermap_api_key

# Battery config
BATTERY_CAPACITY_WH=15000
BATTERY_SAFETY_CUTOFF=20

# Notifications (all optional — enable what you want)
NTFY_TOPIC=your-secret-topic          # iOS push via ntfy.sh (free)
NTFY_URL=https://ntfy.sh              # Or self-hosted ntfy server
IMESSAGE_TO=your@apple.id             # iMessage to iPhone/iPad/Watch
WHATSAPP_PHONE=+1234567890            # WhatsApp via wa.me link

# General
CHECK_INTERVAL=300
WEB_PORT=8077
PLANT_CREATED=2025-01-01
